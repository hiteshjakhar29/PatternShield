# PatternShield Backend - Environment Configuration
# Copy this file to .env and customize for your deployment

# ============================================================================
# FLASK CONFIGURATION
# ============================================================================

# Environment: development, production
FLASK_ENV=production

# Debug mode (NEVER enable in production)
FLASK_DEBUG=False

# Secret key for session management (MUST change in production!)
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-here-change-this

# Server port (default: 5000)
PORT=5000

# ============================================================================
# CORS CONFIGURATION
# ============================================================================

# Allowed origins (comma-separated)
# Examples:
#   - Single origin: https://example.com
#   - Multiple: https://example.com,https://app.example.com
#   - Chrome extension: chrome-extension://your-extension-id
#   - All (dev only): *
CORS_ORIGINS=*

# ============================================================================
# RATE LIMITING
# ============================================================================

# Enable rate limiting
RATE_LIMIT_ENABLED=True

# Requests per hour (per IP)
RATE_LIMIT_PER_HOUR=100

# Requests per minute (per IP)
RATE_LIMIT_PER_MINUTE=20

# ============================================================================
# AUTHENTICATION
# ============================================================================

# Require API key for requests
API_KEY_REQUIRED=False

# API key for authentication (if enabled)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
API_KEY=

# ============================================================================
# LOGGING
# ============================================================================

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ============================================================================
# OPTIONAL: MONITORING & OBSERVABILITY
# ============================================================================

# Sentry DSN for error tracking (optional)
# SENTRY_DSN=https://your-sentry-dsn

# ============================================================================
# OPTIONAL: DATABASE (if using in future)
# ============================================================================

# DATABASE_URL=postgresql://user:pass@localhost:5432/patternshield

# ============================================================================
# OPTIONAL: REDIS (for distributed rate limiting)
# ============================================================================

# REDIS_URL=redis://localhost:6379/0

# ============================================================================
# DEPLOYMENT PLATFORM SPECIFIC
# ============================================================================

# Render.com
# (No specific vars needed, uses PORT automatically)

# Railway
# (No specific vars needed, uses PORT automatically)

# AWS/Heroku
# Use their platform-specific environment variables
