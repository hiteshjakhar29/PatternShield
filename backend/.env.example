# PatternShield v3.0 — Environment Variables Reference
# Copy this file to .env and fill in real values.
# NEVER commit .env to source control.

# ── Flask ─────────────────────────────────────────────────────────────────────
FLASK_ENV=development
FLASK_DEBUG=false
PORT=5000
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-in-production

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite (default — zero config, ideal for local dev and demo)
DATABASE_URL=sqlite:///data/patternshield.db

# PostgreSQL (for production — replace the line above with this)
# DATABASE_URL=postgresql://user:password@localhost:5432/patternshield

# Print SQLAlchemy SQL statements to stdout (useful for debugging)
DB_ECHO=false

# ── LLM Integration (Anthropic Claude) ───────────────────────────────────────
# Get your key at: https://console.anthropic.com/
# Leave blank to run in rule-based-only mode (all other features still work).
ANTHROPIC_API_KEY=

# Claude model for dark pattern analysis
# claude-haiku-4-5-20251001  — fastest, cheapest (default, recommended)
# claude-sonnet-4-6          — more accurate, higher cost
LLM_MODEL=claude-haiku-4-5-20251001

# Set false to disable LLM entirely without removing the API key
LLM_ENABLED=true

# Max seconds to wait for an LLM response before timing out and falling back
LLM_TIMEOUT=15

# Minimum rule-based confidence before LLM is called.
# Keeps API cost proportional to detection signal — benign elements are skipped.
LLM_TRIGGER_THRESHOLD=0.25

# ── Security ──────────────────────────────────────────────────────────────────
API_KEY_REQUIRED=false
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
API_KEY=

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_HOUR=500
RATE_LIMIT_PER_MINUTE=60

# ── Detection Thresholds ──────────────────────────────────────────────────────
CONFIDENCE_THRESHOLD=0.30
MAX_TEXT_LENGTH=2000
MAX_BATCH_SIZE=100

# ── Storage (legacy JSONL — still used as fast append log) ───────────────────
FEEDBACK_FILE=data/feedback.jsonl
TEMPORAL_FILE=data/temporal.json

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGINS=*

# ── Future: Async workers (Celery + Redis) ────────────────────────────────────
# Uncomment when migrating batch analysis to async workers.
# The task_queue.py module is pre-wired for this migration.
# REDIS_URL=redis://localhost:6379/0
# CELERY_WORKER_CONCURRENCY=4
