{
  "manifest_version": 3,
  "name": "PatternShield",
  "version": "2.1.0",
  "description": "AI-powered dark pattern detector — 10 categories, trust scoring, temporal fraud detection, offline mode, and explainable detections.",

  "permissions": [
    "activeTab",
    "storage",
    "scripting",
    "alarms",
    "tabs",
    "notifications"
  ],

  "host_permissions": [
    "http://localhost:5000/*",
    "http://127.0.0.1:5000/*",
    "https://*.render.com/*",
    "https://*.railway.app/*",
    "https://*.onrender.com/*"
  ],

  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16":  "icons/icon16.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "options_page": "options/options.html",

  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "background": {
    "service_worker": "background/background.js"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": [
        "utils/config.js",
        "utils/api.js",
        "content/floating-panel.js",
        "content/content.js"
      ],
      "css": [
        "content/content.css",
        "content/floating-panel.css"
      ],
      "run_at": "document_idle"
    }
  ],

  "web_accessible_resources": [
    {
      "resources": ["icons/*.png"],
      "matches": ["<all_urls>"]
    }
  ]
}
